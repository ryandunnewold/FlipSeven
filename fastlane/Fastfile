default_platform(:ios)

API_KEY = app_store_connect_api_key(
  key_id: "92FN54VUW7",
  issuer_id: "69a6de98-0f96-47e3-e053-5b8c7c11a4d1",
  key_filepath: File.expand_path("~/.appstore/AuthKey_92FN54VUW7.p8")
)

platform :ios do
  desc "Capture App Store screenshots"
  lane :screenshots do
    capture_screenshots(scheme: "FlipSevenUITests")
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    increment_build_number
    build_app(
      scheme: "FlipSeven",
      export_method: "app-store"
    )
    upload_to_testflight(
      api_key: API_KEY,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Upload screenshots to App Store Connect"
  lane :upload_screenshots do
    upload_to_app_store(
      api_key: API_KEY,
      skip_binary_upload: true,
      skip_metadata: true,
      overwrite_screenshots: true,
      force: true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Full App Store release: screenshots, build, and upload"
  lane :release do
    screenshots
    build_app(
      scheme: "FlipSeven",
      export_method: "app-store"
    )
    upload_to_app_store(
      api_key: API_KEY,
      force: true,
      submit_for_review: false
    )
  end
end
